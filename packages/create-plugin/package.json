{
  "name": "@nexora/create-plugin",
  "version": "0.1.1",
  "description": "Scaffold a new Nexora database driver plugin in seconds.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/privixy/nexora.git",
    "directory": "packages/create-plugin"
  },
  "bugs": {
    "url": "https://github.com/privixy/nexora/issues"
  },
  "homepage": "https://github.com/privixy/nexora/tree/main/packages/create-plugin#readme",
  "keywords": [
    "nexora",
    "create-nexora-plugin",
    "scaffold",
    "template",
    "database-plugin",
    "rust"
  ],
  "type": "module",
  "bin": {
    "nexora-create-plugin": "./dist/cli.js"
  },
  "files": [
    "dist",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "vitest run --exclude tests/package-lifecycle.test.ts --exclude tests/smoke.test.ts",
    "typecheck": "tsc --noEmit -p tsconfig.test.json",
    "build": "rm -rf .tmp/templates-stage && cp -R templates .tmp/templates-stage && rm -rf .tmp/templates && mv .tmp/templates-stage .tmp/templates && tsup --out-dir .tmp/build",
    "clean": "rm -rf .tmp/build .tmp/templates",
    "smoke": "tsx scripts/smoke.ts",
    "smoke:static": "tsx scripts/smoke.ts --skip-cargo",
    "pack:stage": "tsx scripts/stage-package.ts",
    "pack:check": "tsx scripts/check-package.ts",
    "check": "pnpm test && pnpm typecheck && pnpm build && pnpm smoke:static && pnpm smoke && pnpm pack:stage && pnpm pack:check",
    "prepack": "pnpm check",
    "prepublishOnly": "pnpm check"
  },
  "dependencies": {
    "kleur": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsup": "^8.3.5",
    "tsx": "^4.23.1",
    "typescript": "~5.9.3",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
