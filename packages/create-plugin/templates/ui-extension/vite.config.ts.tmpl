import { defineConfig } from "vite";
import react from "@vitejs/plugin-react";

// Build the plugin UI as a single IIFE bundle that the Nexora host can
// execute at runtime. React, react/jsx-runtime and @nexora/plugin-api
// are provided by the host as globals — do not bundle them.
//
// The `name` must be `__nexora_plugin__`: the host reads this global
// to retrieve the component. Do not change it.
export default defineConfig({
  plugins: [react()],
  build: {
    outDir: "dist",
    emptyOutDir: true,
    lib: {
      entry: "src/index.tsx",
      formats: ["iife"],
      name: "__nexora_plugin__",
      fileName: () => "index.js",
    },
    rollupOptions: {
      external: ["react", "react/jsx-runtime", "@nexora/plugin-api"],
      output: {
        globals: {
          react: "React",
          "react/jsx-runtime": "ReactJSXRuntime",
          "@nexora/plugin-api": "__NEXORA_API__",
        },
      },
    },
  },
});
