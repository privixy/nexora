{
  "name": "@nexora/plugin-api",
  "version": "0.1.0",
  "description": "Public API surface for Nexora plugin UI extensions.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/privixy/nexora.git",
    "directory": "packages/plugin-api"
  },
  "bugs": {
    "url": "https://github.com/privixy/nexora/issues"
  },
  "homepage": "https://github.com/privixy/nexora/tree/main/packages/plugin-api#readme",
  "keywords": [
    "nexora",
    "plugin",
    "plugin-api",
    "database-client"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.test.json && tsc --noEmit -p tsconfig.contract.json",
    "build": "tsup --out-dir .tmp/build",
    "check:sync": "tsx scripts/check-sync.ts",
    "pack:stage": "tsx scripts/stage-package.ts",
    "pack:check": "tsx scripts/check-package.ts",
    "check": "pnpm test && pnpm typecheck && pnpm build && pnpm check:sync && pnpm pack:stage && pnpm pack:check",
    "clean": "rm -rf .tmp/build",
    "prepack": "pnpm check",
    "prepublishOnly": "pnpm check"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "react": "^19.2.7",
    "tsup": "^8.3.5",
    "tsx": "^4.23.1",
    "typescript": "~5.9.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
