{
  "name": "nexora",
  "private": true,
  "version": "1.0.0",
  "description": "Open-source desktop SQL workspace for PostgreSQL, MySQL/MariaDB, SQLite, and plugin-driven database integrations.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/privixy/nexora.git"
  },
  "bugs": {
    "url": "https://github.com/privixy/nexora/issues"
  },
  "homepage": "https://github.com/privixy/nexora#readme",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "test:coverage": "vitest run --coverage",
    "test:rust": "cd src-tauri && cargo test",
    "test:all": "pnpm test:rust && pnpm test:coverage",
    "tauri": "tauri",
    "build:plugin-api": "pnpm --filter @nexora/plugin-api build",
    "check:plugin-api": "pnpm --filter @nexora/plugin-api check:sync",
    "build:create-plugin": "pnpm --filter @nexora/create-plugin build",
    "smoke:create-plugin": "pnpm --filter @nexora/create-plugin smoke",
    "roadmap": "node scripts/update-roadmap.js",
    "version": "node scripts/sync-version.js && conventional-changelog -p angular -i CHANGELOG.md -s && git add README.md CHANGELOG.md src-tauri/tauri.conf.json src-tauri/Cargo.toml src-tauri/Cargo.lock src/version.ts"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@tailwindcss/postcss": "^4.3.3",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.14.6",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-clipboard-manager": "~2.3.2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-notification": "^2.3.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-updater": "~2.10.1",
    "@types/dagre": "^0.7.54",
    "@xyflow/react": "^12.11.2",
    "buffer": "^6.0.3",
    "clsx": "^2.1.1",
    "dagre": "^0.8.5",
    "emoji-picker-react": "^4.19.1",
    "fuse.js": "^7.5.0",
    "i18next": "^26.3.6",
    "i18next-browser-languagedetector": "^8.2.1",
    "json-edit-react": "^1.30.2",
    "lucide-react": "^1.25.0",
    "monaco-editor": "^0.55.1",
    "process": "^0.11.10",
    "react": "^19.2.7",
    "react-colorful": "^5.8.0",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.10",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.1",
    "recharts": "^3.9.2",
    "sql-formatter": "^15.8.2",
    "util": "^0.12.5",
    "wkx": "^0.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2.11.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "autoprefixer": "^10.5.4",
    "conventional-changelog": "^8.1.0",
    "conventional-changelog-angular": "^9.2.1",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.19",
    "tailwindcss": "^4.3.3",
    "typescript": "~7.0.2",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "packageManager": "pnpm@10.30.3"
}
