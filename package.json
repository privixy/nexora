{
  "name": "nexora",
  "private": true,
  "version": "1.0.3",
  "description": "Open-source desktop SQL workspace for PostgreSQL, MySQL/MariaDB, SQLite, and plugin-driven database integrations.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/privixy/nexora.git"
  },
  "bugs": {
    "url": "https://github.com/privixy/nexora/issues"
  },
  "homepage": "https://github.com/privixy/nexora#readme",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @nexora/desktop dev",
    "build": "pnpm --filter @nexora/desktop build",
    "lint": "eslint .",
    "lint:workflows": "node scripts/run-actionlint.mjs",
    "preview": "pnpm --filter @nexora/desktop preview",
    "test": "vitest --config vitest.config.ts",
    "test:repository": "vitest --config vitest.config.ts --project repository",
    "test:desktop": "vitest --config vitest.config.ts --project desktop",
    "check:architecture": "node scripts/check-architecture.mjs",
    "typecheck": "pnpm --filter @nexora/desktop typecheck",
    "test:coverage": "pnpm --filter @nexora/desktop test:coverage",
    "test:rust": "cargo test --manifest-path apps/desktop/src-tauri/Cargo.toml",
    "test:all": "pnpm test:rust && pnpm test:coverage",
    "tauri": "pnpm --filter @nexora/desktop tauri",
    "test:plugin-api": "pnpm --filter @nexora/plugin-api test",
    "typecheck:plugin-api": "pnpm --filter @nexora/plugin-api typecheck",
    "build:plugin-api": "pnpm --filter @nexora/plugin-api build",
    "check:plugin-api": "pnpm --filter @nexora/plugin-api check:sync",
    "pack:plugin-api": "pnpm --filter @nexora/plugin-api pack:stage && pnpm --filter @nexora/plugin-api pack:check",
    "build:create-plugin": "pnpm --filter @nexora/create-plugin build",
    "smoke:create-plugin": "pnpm --filter @nexora/create-plugin smoke",
    "roadmap": "node scripts/update-roadmap.js",
    "version": "node scripts/sync-version.js && conventional-changelog -p angular -i CHANGELOG.md -s && git add README.md CHANGELOG.md apps/desktop/package.json apps/desktop/src-tauri/tauri.conf.json apps/desktop/src-tauri/Cargo.toml apps/desktop/src-tauri/Cargo.lock apps/desktop/src/version.ts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "conventional-changelog": "^8.1.0",
    "conventional-changelog-angular": "^9.2.1",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  },
  "packageManager": "pnpm@10.30.3",
  "pnpm": {
    "overrides": {
      "@tauri-apps/api": "2.10.1"
    }
  }
}
